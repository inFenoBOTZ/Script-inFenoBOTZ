-- [[ FUNCTION UTALITAS UNTUK BIKIN UI BIAR RAPI ]]
local function createButton(name, text, callback)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansSemibold
    btn.TextSize = 16
    local clr = Instance.new("UICorner") clr.CornerRadius = UDim.new(0, 6) clr.Parent = btn
    btn.MouseButton1Click:Connect(callback)
    btn.Parent = Content
    return btn
end

local function createTextBox(name, placeholder, callback)
    local box = Instance.new("TextBox")
    box.Name = name
    box.Size = UDim2.new(1, -10, 0, 35)
    box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    box.PlaceholderText = placeholder
    box.Text = ""
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.Font = Enum.Font.SourceSans
    box.TextSize = 14
    local clr = Instance.new("UICorner") clr.CornerRadius = UDim.new(0, 6) clr.Parent = box
    box.FocusLost:Connect(function(enterPressed)
        if enterPressed then callback(box.Text) end
    end)
    box.Parent = Content
    return box
end

-- [[ LOGIKAFITUR / FEATURES LOGIC ]]

-- 1. Fly Feature
local flyBtn = createButton("FlyBtn", "Fly: OFF", function()
    flying = not flying
    local btn = Content:FindFirstChild("FlyBtn")
    if flying then
        btn.Text = "Fly: ON"
        btn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        
        local character = LocalPlayer.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then return end
        local hrp = character.HumanoidRootPart
        
        local bv = Instance.new("BodyVelocity")
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(0, 0, 0)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = hrp
        
        local bg = Instance.new("BodyGyro")
        bg.Name = "FlyBG"
        bg.MaxTorque = Vector3.new(0, 0, 0)
        bg.CFrame = hrp.CFrame
        bg.Parent = hrp
        
        task.spawn(function()
            local camera = Workspace.CurrentCamera
            while flying and character and hrp do
                bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
                bg.CFrame = camera.CFrame
                
                local dir = Vector3.new(0,0,0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
                
                bv.Velocity = dir.Unit * flySpeed
                if dir --[[Jika diam]] == Vector3.new(0,0,0) then bv.Velocity = Vector3.new(0,0,0) end
                task.wait()
            end
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
        end)
    else
        btn.Text = "Fly: OFF"
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    end
end)

