-- 6. Dimensi Sendiri (Void Workspace/Isolated Area)
-- Fitur ini memindahkanmu ke koordinat yang sangat jauh (99999) dan membuat sebuah platform sendiri agar aman dari player lain.
local dimensionPlatform = nil
DimensionBtn.MouseButton1Click:Connect(function()
    in_own_dimension = not in_own_dimension
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if in_own_dimension then
        original_cframe = hrp.CFrame
        
        -- Buat platform dimensi baru
        dimensionPlatform = Instance.new("Part")
        dimensionPlatform.Size = Vector3.new(100, 2, 100)
        dimensionPlatform.Position = Vector3.new(99999, 5000, 99999)
        dimensionPlatform.Anchored = true
        dimensionPlatform.Material = Enum.Material.Neon
        dimensionPlatform.Color = Color3.fromRGB(0, 0, 0)
        dimensionPlatform.Parent = workspace
        
        -- TP ke dimensi baru
        wait(0.1)
        hrp.CFrame = CFrame.new(99999, 5003, 99999)
        DimensionBtn.Text = "Dimensi Sendiri: ON"
        DimensionBtn.BackgroundColor3 = Color3.fromRGB(40, 150, 40)
    else
        -- Kembali ke map utama
        if original_cframe then
            hrp.CFrame = original_cframe
        end
        if dimensionPlatform then
            dimensionPlatform:Destroy()
        end
        DimensionBtn.Text = "Dimensi Sendiri: OFF"
        DimensionBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 150)
    end
end)

-- 7. Pemulihan Waktu 1:60 (Time Dilatation / Slow Motion Effect)
-- Menggunakan manipulasi ClockTime lokal sehingga siklus waktu berjalan 60x lebih lambat atau cepat dari normal.
local time_restoration = false
TimeBtn.MouseButton1Click:Connect(function()
    time_restoration = not time_restoration
    if time_restoration then
        TimeBtn.Text = "Pemulihan Waktu: ON"
        TimeBtn.BackgroundColor3 = Color3.fromRGB(40, 150, 40)
    else
        TimeBtn.Text = "Pemulihan Waktu: OFF"
        TimeBtn.BackgroundColor3 = Color3.fromRGB(200, 120, 0)
    end
end)

-- Loop Pemulihan Waktu (1 detik di real life = 60 detik / 1 menit di game secara visual lokal)
spawn(function()
    while true do
        if time_restoration then
            -- 1:60 Ratio Effect pada siklus pencahayaan langit game
            Lighting.ClockTime = Lighting.ClockTime + (1/60)
        end
        math.randomseed(os.time())
        wait(0.1)
    end
end)
