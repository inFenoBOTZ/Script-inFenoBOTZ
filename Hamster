-- 3. WalkSpeed Feature
SpeedBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local num = tonumber(SpeedBox.Text)
        if num then
            speed_value = num
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.WalkSpeed = speed_value
            end
        end
    end
end)

-- Loop speed agar tidak ter-reset game
RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        if LocalPlayer.Character.Humanoid.WalkSpeed ~= speed_value and not flying then
            LocalPlayer.Character.Humanoid.WalkSpeed = speed_value
        end
    end
end)

-- Mendapatkan target player berdasarkan nama parsial
local function getTargetPlayer()
    local text = PlayerTargetBox.Text:lower()
    for _, plyr in pairs(Players:GetPlayers()) do
        if plyr.Name:lower():sub(1, #text) == text or plyr.DisplayName:lower():sub(1, #text) == text then
            return plyr
        end
    end
    return nil
end

