-- Membuat Tombol Logo Bisa Digeser (Draggable)
local dragLogo, logInput, logStart, logPos
MinimizeImg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragLogo = true
        logStart = input.Position
        logPos = MinimizeImg.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragLogo = false end
        end)
    end
end)
MinimizeImg.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then logInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == logInput and dragLogo then
        local delta = input.Position - logStart
        MinimizeImg.Position = UDim2.new(logPos.X.Scale, logPos.X.Offset + delta.x, logPos.Y.Scale, logPos.Y.Offset + delta.y)
    end
end)
